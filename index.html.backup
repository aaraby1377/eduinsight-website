    function showDetail(toolKey) {
      const tool = toolData[toolKey];
      const content = document.getElementById('detail-content');
      content.innerHTML = `
    <div class="detail-header">
      <span class="detail-icon">${tool.icon}</span>
      <div>
        <div class="detail-title">${tool.title}</div>
        <span class="detail-badge">${tool.badge}</span>
      </div>
    </div>
    <div class="detail-divider"></div>
    <div class="detail-section-title">Overview</div>
    <div class="detail-text">${tool.overview}</div>
    <div class="detail-section-title">Key Features</div>
    <ul class="feature-list">
      ${tool.features.map(f => `<li>${f}</li>`).join('')}
    </ul>
    <div class="detail-divider"></div>
    <div class="detail-section-title">Use Cases</div>
    <div>
      ${tool.useCases.map(u => `<span class="use-case-tag">${u}</span>`).join('')}
    </div>
  `;
      document.getElementById('tools-page').style.display = 'none';
      document.getElementById('detail-page').style.display = 'block';
    }

    function goBack() {
      document.getElementById('detail-page').style.display = 'none';
      document.getElementById('tools-page').style.display = 'block';
    }

    // Enhanced Navigation functionality
    document.addEventListener('DOMContentLoaded', function () {
      const navLinks = document.querySelectorAll('.nav-link[href^="#"]');
      const sections = document.querySelectorAll('section[id]');
      const breadcrumb = document.getElementById('breadcrumb');
      const currentPage = document.getElementById('currentPage');

      // Section names for breadcrumbs
      const sectionNames = {
        'home': 'Home',
        'about': 'About',
        'domain': 'Domain',
        'tools': 'Tools',
        'milestones': 'Milestones',
        'docs': 'Documents',
        'team': 'Team',
        'contact': 'Contact'
      };

      // Search index for search functionality
      const searchIndex = [
        { id: 'home', title: 'Home', description: 'Welcome to EduInsight - AI-Powered Academic Performance System', keywords: ['home', 'welcome', 'introduction', 'eduinsight'] },
        { id: 'about', title: 'About', description: 'Learn about EduInsight features and AI-based content analysis', keywords: ['about', 'features', 'ai', 'analysis', 'learning'] },
        { id: 'domain', title: 'Domain', description: 'Explore the academic domain and problem background', keywords: ['domain', 'background', 'academic', 'education', 'slit'] },
        { id: 'tools', title: 'Tools & Technologies', description: 'Discover the technologies used in EduInsight', keywords: ['tools', 'technologies', 'react', 'python', 'mongodb', 'fastapi'] },
        { id: 'milestones', title: 'Milestones', description: 'Track project progress and achievements', keywords: ['milestones', 'progress', 'timeline', 'achievements', 'project'] },
        { id: 'docs', title: 'Documents', description: 'Access project documents and reports', keywords: ['documents', 'reports', 'proposals', 'research', 'papers'] },
        { id: 'team', title: 'Team', description: 'Meet the team members behind EduInsight', keywords: ['team', 'members', 'supervisors', 'students', 'developers'] },
        { id: 'contact', title: 'Contact', description: 'Get in touch with the EduInsight team', keywords: ['contact', 'email', 'phone', 'reach', 'communication'] }
      ];

      // Update breadcrumb function
      function updateBreadcrumb(sectionId) {
        if (sectionId === 'home') {
          breadcrumb.style.display = 'none';
        } else {
          breadcrumb.style.display = 'block';
          currentPage.textContent = sectionNames[sectionId] || sectionId;
        }
      }

      // Handle navigation clicks
      navLinks.forEach(link => {
        link.addEventListener('click', function (e) {
          e.preventDefault();

          // Remove active class from all links
          navLinks.forEach(l => l.classList.remove('active'));

          // Add active class to clicked link
          this.classList.add('active');

          // Scroll to section
          const targetId = this.getAttribute('href').substring(1);
          const targetSection = document.getElementById(targetId);
          if (targetSection) {
            targetSection.scrollIntoView({ behavior: 'smooth' });
            updateBreadcrumb(targetId);
          }
        });
      });

      // Update active nav link on scroll with improved accuracy
      function updateActiveNavigation() {
        let current = '';
        const scrollPosition = window.scrollY + 150; // Offset for better detection

        sections.forEach(section => {
          const sectionTop = section.offsetTop;
          const sectionBottom = sectionTop + section.offsetHeight;
          
          if (scrollPosition >= sectionTop && scrollPosition < sectionBottom) {
            current = section.getAttribute('id');
          }
        });

        // Update navigation links
        navLinks.forEach(link => {
          link.classList.remove('active');
          if (link.getAttribute('href') === '#' + current) {
            link.classList.add('active');
          }
        });

        // Update breadcrumb
        if (current) {
          updateBreadcrumb(current);
        }
      }

      window.addEventListener('scroll', updateActiveNavigation);

      // Search functionality
      window.toggleSearch = function() {
        const searchModal = document.getElementById('searchModal');
        const searchInput = document.getElementById('searchInput');
        
        if (searchModal.style.display === 'none') {
          searchModal.style.display = 'flex';
          searchInput.focus();
        } else {
          searchModal.style.display = 'none';
          searchInput.value = '';
          document.getElementById('searchResults').innerHTML = '';
        }
      };

      window.performSearch = function(event) {
        const query = event.target.value.toLowerCase().trim();
        const resultsContainer = document.getElementById('searchResults');
        
        if (query.length < 2) {
          resultsContainer.innerHTML = '';
          return;
        }

        const results = searchIndex.filter(item => {
          return item.title.toLowerCase().includes(query) ||
                 item.description.toLowerCase().includes(query) ||
                 item.keywords.some(keyword => keyword.toLowerCase().includes(query));
        });

        if (results.length === 0) {
          resultsContainer.innerHTML = '<div class="search-result-item"><p>No results found</p></div>';
        } else {
          resultsContainer.innerHTML = results.map(item => `
            <div class="search-result-item" onclick="navigateToSection('${item.id}')">
              <h4>${item.title}</h4>
              <p>${item.description}</p>
            </div>
          `).join('');
        }

        // Handle Enter key
        if (event.key === 'Enter' && results.length > 0) {
          navigateToSection(results[0].id);
        }
      };

      window.navigateToSection = function(sectionId) {
        const targetSection = document.getElementById(sectionId);
        if (targetSection) {
          targetSection.scrollIntoView({ behavior: 'smooth' });
          toggleSearch(); // Close search modal
          
          // Update navigation
          navLinks.forEach(link => {
            link.classList.remove('active');
            if (link.getAttribute('href') === '#' + sectionId) {
              link.classList.add('active');
            }
          });
          
          updateBreadcrumb(sectionId);
        }
      };

      // Close search on Escape key
      document.addEventListener('keydown', function(event) {
        if (event.key === 'Escape') {
          const searchModal = document.getElementById('searchModal');
          if (searchModal.style.display !== 'none') {
            toggleSearch();
          }
        }
      });

      // Initialize breadcrumb on load
      updateActiveNavigation();
      
      // Domain button functionality
      const buttons = document.querySelectorAll('.domain-button');
      const contentItems = document.querySelectorAll('.content-item');

      buttons.forEach(button => {
        button.addEventListener('click', function () {
          // Remove active class from all buttons and content
          buttons.forEach(btn => btn.classList.remove('active'));
          contentItems.forEach(item => item.classList.remove('active'));

          // Add active class to clicked button
          this.classList.add('active');

          // Show corresponding content
          const contentType = this.getAttribute('data-content');
          const targetContent = document.getElementById(contentType + '-content');
          console.log('Button clicked:', contentType, 'Target:', targetContent);
          if (targetContent) {
            targetContent.classList.add('active');
            console.log('Added active class to:', targetContent.id);
          } else {
            console.error('Target content not found:', contentType + '-content');
          }
        });
      });
    });

    // Contact form: send via FormSubmit AJAX — stay on this page, no redirect to formsubmit.co
    (function () {
      const form = document.getElementById("eduinsight-contact-form");
      if (!form) {
        return;
      }
      form.addEventListener("submit", async function (e) {
        e.preventDefault();
        const honey = form.querySelector('input[name="_honey"]');
        if (honey && honey.value) {
          return;
        }
        const formData = new FormData(form);
        try {
          const response = await fetch(form.action, {
            method: "POST",
            body: formData,
            headers: {
              'Accept': 'application/json'
            }
          });
          const data = await response.json();
          if (response.ok) {
            alert("Message sent successfully!");
            form.reset();
          } else {
            alert("Message not sent. " + ((data && data.message) || "Please try again."));
          }
        } catch (err) {
          alert("Message not sent. Check your network and try again.");
        }
      });
    })();

    // Scroll to top functionality
    function scrollToTop() {
      window.scrollTo({
        top: 0,
        behavior: "smooth",
      });
    }
    
    // Add scroll detection for scroll-to-top button visibility
    function handleScrollToTopButton() {
      const scrollButton = document.querySelector('.scroll-to-top');
      if (!scrollButton) return;
      
      // Get the Contact Us section position
      const contactSection = document.getElementById('contact');
      if (!contactSection) return;
      
      const contactSectionTop = contactSection.offsetTop;
      
      // Only show button when scrolled to Contact Us section or below
      if (window.scrollY >= contactSectionTop - 100) {
        scrollButton.classList.add('visible');
      } else {
        scrollButton.classList.remove('visible');
      }
    }

    // Add scroll event listener
    window.addEventListener('scroll', handleScrollToTopButton);

    // Initialize scroll-to-top button visibility
    handleScrollToTopButton();

    // Scroll to contact function
    function scrollToContact() {
      const contactSection = document.getElementById('contact');
      if (contactSection) {
        contactSection.scrollIntoView({ behavior: 'smooth' });
      }
    }
  </script>
</body>

</html>
