  <!-- Contact Section -->
  <section id="contact" class="contact-section">
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap');

      .contact-section {
        background: linear-gradient(135deg, #eff6ff 0%, #f8fbff 50%, #edf4ff 100%);
        min-height: 100vh;
        padding: 120px 0 80px;
      }

      .contact-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 40px;
      }

      .page-title {
        text-align: center;
        font-size: 48px;
        font-weight: 700;
        background: linear-gradient(135deg, #2563eb, #2563eb);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 60px;
      }

      .contact-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 60px;
        align-items: start;
      }

      .contact-info {
        display: flex;
        flex-direction: column;
        gap: 30px;
      }

      .contact-card {
        background: rgba(255, 255, 255, 0.9);
        border: 1px solid rgba(37, 99, 235, 0.1);
        border-radius: 16px;
        padding: 30px;
        text-align: center;
        transition: transform 0.3s, box-shadow 0.3s;
        box-shadow: 0 4px 20px rgba(37, 99, 235, 0.08);
      }

      .contact-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 12px 40px rgba(37, 99, 235, 0.15);
      }

      .contact-icon {
        font-size: 2.5rem;
        margin-bottom: 15px;
      }

      .contact-card h3 {
        font-size: 1.2rem;
        font-weight: 600;
        color: #1f2937;
        margin-bottom: 10px;
      }

      .contact-card p {
        font-size: 0.95rem;
        color: #6b7280;
        line-height: 1.5;
      }

      .contact-card a {
        color: #2563eb;
        text-decoration: none;
        font-weight: 500;
      }

      .contact-card a:hover {
        text-decoration: underline;
      }

      .contact-form {
        background: rgba(255, 255, 255, 0.9);
        border: 1px solid rgba(37, 99, 235, 0.1);
        border-radius: 20px;
        padding: 40px;
        box-shadow: 0 4px 20px rgba(37, 99, 235, 0.08);
      }

      .form-group {
        margin-bottom: 25px;
      }

      .form-group label {
        display: block;
        font-size: 0.9rem;
        font-weight: 600;
        color: #374151;
        margin-bottom: 8px;
      }

      .form-group input,
      .form-group textarea {
        width: 100%;
        padding: 12px 16px;
        border: 1px solid rgba(37, 99, 235, 0.2);
        border-radius: 10px;
        font-size: 0.9rem;
        font-family: 'Poppins', sans-serif;
        transition: border-color 0.3s, box-shadow 0.3s;
        background: rgba(255, 255, 255, 0.8);
      }

      .form-group input:focus,
      .form-group textarea:focus {
        outline: none;
        border-color: #2563eb;
        box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
      }

      .form-group textarea {
        resize: vertical;
        min-height: 120px;
      }

      .submit-btn {
        width: 100%;
        padding: 14px 24px;
        background: linear-gradient(135deg, #2563eb, #3b82f6);
        color: white;
        border: none;
        border-radius: 10px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: transform 0.3s, box-shadow 0.3s;
        font-family: 'Poppins', sans-serif;
      }

      .submit-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(37, 99, 235, 0.3);
      }

      @media (max-width: 768px) {
        .contact-container {
          padding: 0 20px;
        }

        .page-title {
          font-size: 36px;
        }

        .contact-grid {
          grid-template-columns: 1fr;
          gap: 40px;
        }

        .contact-form {
          padding: 30px 25px;
        }
      }
    </style>

    <div class="contact-container">
      <h1 class="page-title"><span class="heading-icon">📧</span>Contact Us</h1>

      <div class="contact-grid">
        <div class="contact-info">
          <div class="contact-card">
            <div class="contact-icon">📧</div>
            <h3>Email</h3>
            <p><a href="mailto:eduinsight@sliit.lk">eduinsight@sliit.lk</a></p>
          </div>

          <div class="contact-card">
            <div class="contact-icon">📱</div>
            <h3>Phone Number</h3>
            <p><a href="tel:+94779346476">+94 779 346 476</a></p>
          </div>

          <div class="contact-card">
            <div class="contact-icon">📍</div>
            <h3>Location</h3>
            <p>SLIIT Malabe Campus<br>Colombo, Sri Lanka</p>
          </div>
        </div>

        <div class="contact-form">
          <form id="eduinsight-contact-form" action="https://formsubmit.co/your-email@example.com" method="POST">
            <input type="hidden" name="_subject" value="EduInsight Contact Form Submission">
            <input type="hidden" name="_template" value="table">
            <input type="text" name="_honey" style="display:none">
            
            <div class="form-group">
              <label for="name">Your Name</label>
              <input type="text" id="name" name="name" required>
            </div>

            <div class="form-group">
              <label for="email">Your Email</label>
              <input type="email" id="email" name="email" required>
            </div>

            <div class="form-group">
              <label for="subject">Subject</label>
              <input type="text" id="subject" name="subject" required>
            </div>

            <div class="form-group">
              <label for="message">Message</label>
              <textarea id="message" name="message" required></textarea>
            </div>

            <button type="submit" class="submit-btn">Send Message</button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- Scroll to Top Button -->
  <button class="scroll-to-top" onclick="scrollToTop()">↑</button>

