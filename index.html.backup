  <section id="team" class="team-section">
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap');

      .team-section {
        background: linear-gradient(135deg, #f0f4ff 0%, #ffffff 60%, #f5f7ff 100%);
        min-height: 100vh;
        padding: 120px 0 80px;
      }

      .team-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 40px;
      }

      .page-title {
        text-align: center;
        font-size: 48px;
        font-weight: 700;
        background: linear-gradient(135deg, #2563eb, #2563eb);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 60px;
      }

      .team-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 30px;
        margin-bottom: 50px;
      }

      .team-card {
        background: rgba(255, 255, 255, 0.9);
        border: 1px solid rgba(37, 99, 235, 0.1);
        border-radius: 20px;
        padding: 30px;
        text-align: center;
        transition: transform 0.3s, box-shadow 0.3s;
        box-shadow: 0 4px 20px rgba(37, 99, 235, 0.08);
      }

      .team-card.leader {
        border: 2px solid #2563eb;
        background: linear-gradient(135deg, rgba(37, 99, 235, 0.05), rgba(255, 255, 255, 0.9));
      }

      .team-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 12px 40px rgba(37, 99, 235, 0.15);
      }

      .photo-wrap {
        width: 120px;
        height: 120px;
        margin: 0 auto 20px;
        border-radius: 50%;
        overflow: hidden;
        border: 4px solid #2563eb;
        position: relative;
      }

      .photo-wrap img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .avatar {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        font-weight: 700;
        color: #2563eb;
        background: linear-gradient(135deg, #f0f4ff, #ffffff);
      }

      .card-name {
        font-size: 1.3rem;
        font-weight: 700;
        color: #1f2937;
        margin-bottom: 8px;
      }

      .card-role {
        font-size: 0.95rem;
        font-weight: 600;
        color: #2563eb;
        margin-bottom: 6px;
      }

      .card-regid {
        font-size: 0.85rem;
        color: #6b7280;
        margin-bottom: 12px;
      }

      .card-email {
        font-size: 0.85rem;
        color: #2563eb;
        word-break: break-all;
        line-height: 1.4;
      }

      .card-phone {
        font-size: 0.85rem;
        color: #2563eb;
        word-break: break-all;
        line-height: 1.4;
        margin-top: 4px;
      }

      .supervisors {
        background: rgba(37, 99, 235, 0.05);
        border-radius: 20px;
        padding: 40px;
        text-align: center;
      }

      .supervisors h3 {
        font-size: 1.8rem;
        font-weight: 700;
        color: #2563eb;
        margin-bottom: 30px;
      }

      .supervisor-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 30px;
      }

      .supervisor-card {
        background: rgba(255, 255, 255, 0.9);
        border: 1px solid rgba(37, 99, 235, 0.1);
        border-radius: 15px;
        padding: 25px;
        transition: transform 0.3s, box-shadow 0.3s;
      }

      .supervisor-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 30px rgba(37, 99, 235, 0.12);
      }

      .supervisor-name {
        font-size: 1.1rem;
        font-weight: 600;
        color: #1f2937;
        margin-bottom: 8px;
      }

      .supervisor-title {
        font-size: 0.9rem;
        color: #2563eb;
        margin-bottom: 8px;
      }

      .supervisor-email {
        font-size: 0.8rem;
        color: #6b7280;
      }

      @media (max-width: 768px) {
        .team-container {
          padding: 0 20px;
        }

        .page-title {
          font-size: 36px;
        }

        .team-grid {
          grid-template-columns: 1fr;
          gap: 20px;
        }

        .supervisors {
          padding: 25px;
        }

        .supervisor-grid {
          grid-template-columns: 1fr;
