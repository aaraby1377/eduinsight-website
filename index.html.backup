  <section id="milestones" class="milestones-section">
    <style>
      .milestones-section {
        background: linear-gradient(135deg, #f0f4ff 0%, #ffffff 60%, #f5f7ff 100%);
        min-height: 100vh;
        padding: 120px 0 80px;
      }

      .milestones-container {
        max-width: 900px;
        margin: 0 auto;
        padding: 0 40px;
      }

      .milestones-container .page-title {
        text-align: center;
        font-size: 48px;
        font-weight: 700;
        background: linear-gradient(135deg, #2563eb, #2563eb);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 60px;
      }

      .ms-timeline {
        position: relative;
        padding-left: 68px;
      }

      .ms-timeline::before {
        content: '';
        position: absolute;
        left: 22px;
        top: 12px;
        bottom: 12px;
        width: 2px;
        background: rgba(37, 99, 235, 0.35);
      }

      .ms-item {
        position: relative;
        margin-bottom: 28px;
        animation: msFadeIn 0.4s ease both;
      }

      .ms-item:nth-child(1) {
        animation-delay: 0.05s;
      }

      .ms-item:nth-child(2) {
        animation-delay: 0.10s;
      }

      .ms-item:nth-child(3) {
        animation-delay: 0.15s;
      }

      .ms-item:nth-child(4) {
        animation-delay: 0.20s;
      }

      .ms-item:nth-child(5) {
        animation-delay: 0.25s;
      }

      .ms-item:nth-child(6) {
        animation-delay: 0.30s;
      }

      .ms-item:nth-child(7) {
        animation-delay: 0.35s;
      }

      .ms-item:nth-child(8) {
        animation-delay: 0.40s;
      }

      .ms-dot {
        position: absolute;
        left: -57px;
        top: 20px;
        width: 20px;
        height: 20px;
        border-radius: 50%;
        background: #2563eb;
        border: 3px solid #fff;
        box-shadow: 0 0 0 2px #2563eb;
        z-index: 1;
      }

      .ms-card {
        background: #ffffff;
        border: 1px solid rgba(37, 99, 235, 0.1);
        border-radius: 14px;
        padding: 24px 32px 22px;
        box-shadow: 0 2px 16px rgba(30, 64, 175, 0.06), 0 1px 4px rgba(30, 64, 175, 0.04);
        transition: box-shadow 0.25s, border-color 0.25s;
        position: relative;
      }

      .ms-card:hover {
        box-shadow: 0 6px 28px rgba(37, 99, 235, 0.12);
        border-color: rgba(37, 99, 235, 0.25);
      }

      .ms-title {
        font-size: 1.05rem;
        font-weight: 700;
        color: #1f2937;
        margin-bottom: 4px;
      }

      .ms-date {
        font-size: 0.82rem;
        color: #9ca3af;
        margin-bottom: 10px;
        font-weight: 400;
      }

      .ms-desc {
        font-size: 0.88rem;
        color: #6b7280;
        line-height: 1.65;
      }

      @keyframes msFadeIn {
        from {
          opacity: 0;
          transform: translateY(10px);
        }

        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      @media (max-width: 768px) {
        .milestones-container {
          padding: 0 20px;
        }

        .ms-timeline {
          padding-left: 50px;
        }

        .ms-timeline::before {
          left: 16px;
        }

        .ms-dot {
          left: -42px;
          width: 16px;
          height: 16px;
          top: 22px;
        }

        .milestones-container .page-title {
          font-size: 36px;
        }
      }
    </style>

