<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>EduInsight - AI-Powered Academic Performance</title>
  <link rel="stylesheet" href="style.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    .heading-icon {
      display: inline-block;
      margin-right: 8px;
      background: none !important;
      -webkit-background-clip: border-box !important;
      background-clip: border-box !important;
      -webkit-text-fill-color: initial !important;
      color: initial !important;
    }
  </style>
</head>

<body>
  <!-- Navigation Bar -->
  <nav class="navbar">
    <div class="nav-container">
      <div class="nav-logo">
        <span class="logo-text">Eduinsight</span>
      </div>
      <ul class="nav-links">
        <li><a href="#home" class="nav-link active">Home</a></li>
        <li><a href="#about" class="nav-link">About</a></li>
        <li><a href="#domain" class="nav-link">Domain</a></li>
        <li><a href="#tools" class="nav-link">Tools</a></li>
        <li><a href="#milestones" class="nav-link">Milestones</a></li>
        <li><a href="#docs" class="nav-link">Docs</a></li>
        <li><a href="#team" class="nav-link">Team</a></li>
        <li><a href="#contact" class="nav-link">Contact</a></li>
      </ul>
      <div class="nav-search">
        <button class="search-btn" onclick="toggleSearch()">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"></circle>
            <path d="m21 21-4.35-4.35"></path>
          </svg>
        </button>
      </div>
    </div>
  </nav>

  <!-- Search Modal -->
  <div id="searchModal" class="search-modal" style="display: none;">
    <div class="search-overlay" onclick="toggleSearch()"></div>
    <div class="search-container">
      <div class="search-header">
        <h3>Search Eduinsight</h3>
        <button class="search-close" onclick="toggleSearch()">×</button>
      </div>
      <input type="text" id="searchInput" placeholder="Search for sections, content, or information..." onkeyup="performSearch(event)">
      <div id="searchResults" class="search-results"></div>
    </div>
  </div>

  <!-- Breadcrumb Navigation -->
  <div id="breadcrumb" class="breadcrumb-nav" style="display: none;">
    <div class="breadcrumb-container">
      <a href="#home" class="breadcrumb-item">Home</a>
      <span class="breadcrumb-separator">›</span>
      <span id="currentPage" class="breadcrumb-current"></span>
    </div>
  </div>

  <!-- Home Section -->
  <section id="home" class="hero">
    <div class="hero-container">
      <div class="hero-content">
        <div class="hero-text">
          <h1 class="hero-title">
            <span class="title-gradient">Eduinsight</span> <span class="title-gradient">Smarter</span> Tools, Better
            Grades
          </h1>
          <p class="hero-description">
            Eduinsight uses AI to analyze past papers and lecture content, uncover key patterns, and help students focus
            on what truly matters for better academic performance.
          </p>
          <button class="explore-btn" onclick="document.getElementById('about').scrollIntoView({behavior:'smooth'})">
            <svg class="btn-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2">
              <path
                d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" />
            </svg>
            Explore System
          </button>
        </div>
        <div class="hero-image">
          <div class="image-frame">
            <img src="website-image1.png" alt="EduInsight AI Visualization">
          </div>
        </div>
      </div>
    </div>
    <!-- Scroll Down Button -->
    <button class="scroll-down-btn" onclick="scrollToContact()">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M6 9l6 6 6-6" />
      </svg>
    </button>
  </section>

  <!-- About Section -->
  <section id="about" class="about">
    <div class="about-container">
      <h1 class="about-title"><span class="heading-icon">🌱</span>About EduInsight</h1>
      <p class="about-description">
        EduInsight is an AI powered learning platform built specifically for SLIIT students regarding DMS module.
        Developed by final year undergraduates at SLIIT, it integrates cutting edge technologies such as:
      </p>

      <div class="feature-grid">
        <div class="feature-card">
          <div class="card-icon">🤖</div>
          <h3 class="card-title">AI Based Content Analysis</h3>
          <p class="card-description">
            The system analyzes past exam papers and lecture materials to identify important topics and question
            patterns. It helps generate model exam questions aligned with the syllabus to support effective exam
            preparation.
          </p>
          <p class="card-feature">• Feature: Model Paper Generation</p>
        </div>

        <div class="feature-card">
          <div class="card-icon">📚</div>
          <h3 class="card-title">Syllabus Aware Learning Support</h3>
          <p class="card-description">
            The system provides study materials such as summaries, diagrams, and learning resources to help students
            better understand key concepts. It also supports students in completing assignments and improving their
            subject knowledge.
          </p>
          <p class="card-feature">• Feature: CA Guidance</p>
        </div>

        <div class="feature-card">
          <div class="card-icon">📊</div>
          <h3 class="card-title">Adaptive Evaluation & Feedback System</h3>
          <p class="card-description">
            The system evaluates student answers and provides feedback to improve writing quality. It also tracks
            performance, identifies weak areas, and suggests additional practice to help students improve.
          </p>
          <p class="card-feature">• Feature: Personalized Feedback & Adaptive Learning</p>
        </div>

        <div class="feature-card">
          <div class="card-icon">🎯</div>
          <h3 class="card-title">Adaptive Personalization</h3>
          <p class="card-description">
            The system analyzes student performance in quizzes to identify weak topics. Based on this, it provides
            personalized questions and study recommendations to support targeted learning.
          </p>
          <p class="card-feature">• Feature: Adaptive Study Plans</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Domain Section -->
  <section id="domain" class="domain-section">
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');

      .domain-section {
        background: linear-gradient(135deg, #eff6ff 0%, #f8fbff 50%, #edf4ff 100%);
        min-height: 100vh;
        padding: 120px 0 80px;
      }

      .domain-container {
        max-width: 860px;
        margin: 0 auto;
        padding: 0 24px;
      }

      .section-title {
        text-align: center;
        font-size: 48px;
        font-weight: 700;
        letter-spacing: -0.02em;
        margin-bottom: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        background: linear-gradient(135deg, #2563eb, #2563eb);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .tabs {
        display: flex;
        justify-content: center;
        gap: 12px;
        margin-bottom: 32px;
        flex-wrap: nowrap;
      }

      .tab-btn {
        padding: 9px 22px;
        border-radius: 999px;
        border: 1.5px solid #2563eb;
        background: transparent;
        color: #2563eb;
        font-size: 0.875rem;
        font-weight: 500;
        cursor: pointer;
        transition: background 0.2s, color 0.2s, border-color 0.2s;
        font-family: 'Inter', sans-serif;
      }

      .tab-btn:hover {
        background: rgba(37, 99, 235, 0.1);
        color: #1d4ed8;
      }

      .tab-btn.active {
        background: #2563eb;
        color: #fff;
        border-color: #2563eb;
      }

      .content-card {
        background: #ffffff;
        border: 1px solid rgba(37, 99, 235, 0.12);
        border-left: 5px solid #2563eb;
        border-radius: 0 16px 16px 0;
        padding: 40px 52px;
        text-align: center;
        line-height: 1.75;
        color: #1f2937;
        font-size: 0.95rem;
        box-shadow: 0 4px 24px rgba(37, 99, 235, 0.08);
        animation: fadeIn 0.25s ease;
      }

      .content-card p+p {
        margin-top: 20px;
      }

      .grid-cards {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        animation: fadeIn 0.25s ease;
      }

      .grid-card {
        background: #ffffff;
        border: 1px solid rgba(37, 99, 235, 0.12);
        border-left: 5px solid #2563eb;
        border-radius: 0 14px 14px 0;
        padding: 28px 28px 24px;
        box-shadow: 0 4px 20px rgba(37, 99, 235, 0.07);
      }

      .grid-card h3 {
        font-size: 0.95rem;
        font-weight: 600;
        margin-bottom: 10px;
        display: flex;
        align-items: center;
        gap: 8px;
        color: #1f2937;
      }

      .grid-card p {
        font-size: 0.875rem;
        color: #6b7280;
        line-height: 1.65;
      }

      @keyframes fadeIn {
        from {
          opacity: 0;
          transform: translateY(8px);
        }

        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      @media (max-width: 640px) {
        .content-card {
          padding: 28px 24px;
        }

        .grid-cards {
          grid-template-columns: 1fr;
        }
      }
    </style>

    <div class="domain-container">
      <h1 class="section-title"><span class="heading-icon">🔍</span>Research Domain</h1>

      <div class="tabs">
        <button class="tab-btn active" data-tab="background">Literature Survey</button>
        <button class="tab-btn" data-tab="gap">Research Gap</button>
        <button class="tab-btn" data-tab="problem">Research Problem</button>
        <button class="tab-btn" data-tab="objectives">Research Objectives</button>
        <button class="tab-btn" data-tab="methodology">Methodology</button>
      </div>

      <div id="tab-content"></div>
    </div>
  </section>

  <script>
    const tabs = {
      background: {
        type: 'text',
        paragraphs: [
          "Recent research in AI and NLP has introduced various educational support systems such as automated essay evaluation, past paper analysis, and content summarization. Techniques like TF-IDF, BERT, and GPT are widely used to analyze academic content and generate study materials.",
          "Existing systems provide solutions for specific tasks such as summarization, question generation, or evaluation. However, they do not offer a fully integrated platform that combines exam analysis, syllabus mapping, adaptive feedback, and personalized learning support in a single system."
        ]
      },
      gap: {
        type: 'text',
        paragraphs: [
          "Existing systems mainly focus on either lecture material analysis or past paper analysis separately. They do not provide an integrated solution that combines exam pattern analysis, syllabus mapping, automated evaluation, and personalized learning support.",
          "Additionally, current platforms lack the ability to understand student performance and adapt learning content dynamically based on weak areas.They also do not effectively classify questions based on cognitive levels or provide structured feedback for essay answers. As a result, students receive limited guidance in improving their understanding and exam preparation strategies."
        ]
      },
      problem: {
        type: 'text',
        paragraphs: [
          "Students struggle to identify important topics, understand question difficulty, and prepare effectively for exams due to lack of intelligent support systems.",
          "There is a need for an integrated AI based system that can analyze past papers, map syllabus content, evaluate student answers, and provide personalized feedback and study recommendations.Additionally, such a system should be able to identify weak areas and adapt the learning process based on student performance. It should also provide structured practice and guidance to improve answer quality and exam readiness."
        ]
      },
      methodology: {
        type: 'grid',
        cards: [
          {
            icon: '📄',
            title: 'Model Paper Generation',
            text: 'The component analyzes past exam papers and lecture materials to identify recurring patterns, key topics, and question structures, then uses this knowledge to generate model exam papers and aligned short notes for exam preparation.'
          },
          {
            icon: '🔤',
            title: 'Educational Support',
            text: 'The system provides real-time DMS lecture summaries, generates ER diagrams, and creates flashcards to help students study. It also offers Continuous Assignment (CA) guidance to assist students with their tasks. These features use RAG for content retrieval and multi-agent systems to manage different tasks efficiently.'
          },
          {
            icon: '🧠',
            title: 'Essay Evaluation & Feedback',
            text: 'The system takes questions from past papers and classifies their difficulty. It gives practice questions, checks student answers, and provides feedback. It also tracks progress, finds weak topics, and generates more practice using n8n. Based on performance, it adjusts the difficulty of the next questions to support better learning.'
          },
          {
            icon: '🎯',
            title: 'MCQ Personalization',
            text: 'AI driven module that identifies students' weak topics from quiz performance and adapts study plans and MCQ recommendations using GraphRAG for targeted learning.'
          }
        ]
      },
      objectives: {
        type: 'grid',
        cards: [
          {
            icon: '📄',
            title: 'Objective 01',
            text: 'Develop an AI-based system to analyze past exam papers and lecture slides to generate model exam papers and aligned short notes.'
          },
          {
            icon: '🗂️',
            title: 'Objective 02',
            text: 'Develop a syllabus aware learning support system that provides summaries, flashcards, audio explanations, and CA guidance.'
          },
          {
            icon: '🔮',
            title: 'Objective 03',
            text: 'Develop a system that extracts and classifies questions from past papers based on difficulty, provides practice questions, evaluates student answers with feedback, tracks performance to identify weak topics, and generates additional practice while adapting question difficulty based on student performance to support effective learning.'
          },
          {
            icon: '🔷',
            title: 'Objective 04',
            text: 'Develop an NLP-based personalization system that classifies educational content and generates personalized MCQ study plans.'
          }
        ]
      }
    };

    function renderTab(key) {
      const data = tabs[key];
      const container = document.getElementById('tab-content');

      if (data.type === 'text') {
        container.innerHTML = `
            <div class="content-card">
              ${data.paragraphs.map(p => `<p>${p}</p>`).join('')}
            </div>`;
      } else {
        container.innerHTML = `
            <div class="grid-cards">
              ${data.cards.map(c => `
                <div class="grid-card">
                  <h3>${c.icon} ${c.title}</h3>
                  <p>${c.text}</p>
                </div>`).join('')}
            </div>`;
      }
    }

    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        renderTab(btn.dataset.tab);
      });
    });

    renderTab('background');
  </script>

  <!-- Tools Section -->
  <section id="tools" class="tools-section">
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap');

      .tools-section {
        background: linear-gradient(135deg, #eff6ff 0%, #f8fbff 50%, #edf4ff 100%);
        min-height: 100vh;
        padding: 120px 0 80px;
      }

      .tools-container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 40px;
      }

      .page-title {
        text-align: center;
        font-size: 48px;
        font-weight: 700;
        background: linear-gradient(135deg, #2563eb, #2563eb);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 50px;
      }

      .tools-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        max-width: 1200px;
        margin: 0 auto;
      }

      .tool-card {
        background: rgba(255, 255, 255, 0.05);
        border: 2px solid rgba(255, 255, 255, 0.1);
        border-radius: 18px;
        padding: 40px 24px 30px;
        text-align: center;
        cursor: pointer;
        transition: transform 0.25s, box-shadow 0.25s, border-color 0.25s;
        position: relative;
        overflow: hidden;
      }

      .tool-card::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 4px;
        background: #2563eb;
        border-radius: 4px 0 0 4px;
      }

      .tool-card.highlighted {
        background: rgba(37, 99, 235, 0.1);
        border-color: #2563eb;
      }

      .tool-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 12px 35px rgba(37, 99, 235, 0.2);
        border-color: #2563eb;
      }

      .card-icon {
        font-size: 2.8rem;
        margin-bottom: 16px;
        display: block;
      }

      .card-title {
        font-size: 1.15rem;
        font-weight: 700;
        color: #1f2937;
        margin-bottom: 8px;
      }

      .card-desc {
        font-size: 0.85rem;
        color: #6b7280;
        line-height: 1.5;
      }

      #detail-page {
        display: none;
        padding: 60px 40px;
        min-height: 100vh;
      }

      .back-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #2563eb;
        color: white;
        border: none;
        padding: 10px 22px;
        border-radius: 30px;
        font-size: 0.9rem;
        font-weight: 600;
        cursor: pointer;
        margin-bottom: 40px;
        transition: background 0.2s, transform 0.2s;
        font-family: 'Poppins', sans-serif;
      }

      .back-btn:hover {
        background: #1d4ed8;
        transform: translateX(-3px);
      }

      .detail-card {
        max-width: 800px;
        margin: 0 auto;
        background: rgba(255, 255, 255, 0.05);
        border: 2px solid rgba(37, 99, 235, 0.3);
        border-radius: 24px;
        padding: 50px 50px 40px;
        box-shadow: 0 20px 60px rgba(37, 99, 235, 0.15);
        animation: slideUp 0.4s ease;
      }

      @keyframes slideUp {
        from {
          opacity: 0;
          transform: translateY(30px);
        }

        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      .detail-header {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 30px;
      }

      .detail-icon {
        font-size: 4rem;
      }

      .detail-title {
        font-size: 2rem;
        font-weight: 700;
        color: #1f2937;
      }

      .detail-badge {
        display: inline-block;
        background: rgba(37, 99, 235, 0.2);
        color: #1f2937;
        font-size: 0.8rem;
        font-weight: 600;
        padding: 4px 14px;
        border-radius: 20px;
        margin-top: 6px;
      }

      .detail-divider {
        height: 2px;
        background: linear-gradient(to right, #2563eb, transparent);
        margin: 24px 0;
      }

      .detail-section-title {
        font-size: 0.75rem;
        font-weight: 700;
        color: #2563eb;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        margin-bottom: 10px;
      }

      .detail-text {
        font-size: 0.95rem;
        color: #6b7280;
        line-height: 1.75;
        margin-bottom: 24px;
      }

      .feature-list {
        list-style: none;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        margin-bottom: 24px;
      }

      .feature-list li {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.88rem;
        color: #6b7280;
      }

      .feature-list li::before {
        content: '✓';
        color: #2563eb;
        font-weight: 700;
        font-size: 1rem;
      }

      .use-case-tag {
        display: inline-block;
        background: rgba(37, 99, 235, 0.1);
        border: 1px solid rgba(37, 99, 235, 0.3);
        color: #1f2937;
        padding: 5px 14px;
        border-radius: 20px;
        font-size: 0.82rem;
        font-weight: 500;
        margin: 4px;
      }

      @media (max-width: 1024px) {
        .tools-grid {
          grid-template-columns: repeat(3, 1fr);
        }
      }

      @media (max-width: 768px) {
        .tools-grid {
          grid-template-columns: repeat(2, 1fr);
        }

        .page-title {
          font-size: 36px;
        }
      }

      @media (max-width: 480px) {
        .tools-grid {
          grid-template-columns: 1fr;
        }

        .tools-container {
          padding: 0 20px;
        }
      }
    </style>

    <div class="tools-container">
      <div id="tools-page">
        <h1 class="page-title"><span class="heading-icon">🛠️</span>Tools &amp; Technologies</h1>
        <div class="tools-grid">

          <div class="tool-card">
            <span class="card-icon">⚛️</span>
            <div class="card-title">React</div>
            <div class="card-desc">Frontend UI development</div>
          </div>

          <div class="tool-card highlighted">
            <span class="card-icon">🐍</span>
            <div class="card-title">Python</div>
            <div class="card-desc">AI/ML backend services</div>
          </div>

          <div class="tool-card highlighted">
            <span class="card-icon">🍃</span>
            <div class="card-title">MongoDB</div>
            <div class="card-desc">NoSQL database for analytics</div>
          </div>

          <div class="tool-card highlighted">
            <span class="card-icon">⚡</span>
            <div class="card-title">FastAPI</div>
            <div class="card-desc">Lightweight Python backend</div>
          </div>

          <div class="tool-card">
            <span class="card-icon">🚀</span>
            <div class="card-title">Vite</div>
            <div class="card-desc">Blazing fast dev server for React</div>
          </div>

          <div class="tool-card highlighted">
            <span class="card-icon">☁️</span>
            <div class="card-title">Azure</div>
            <div class="card-desc">Cloud hosting and deployment (CI/CD)</div>
          </div>

          <div class="tool-card">
            <span class="card-icon">🔄</span>
            <div class="card-title">GitHub Actions</div>
            <div class="card-desc">Automation workflows for building, testing, deploying</div>
          </div>

          <div class="tool-card highlighted">
            <span class="card-icon">🔍</span>
            <div class="card-title">OCR (Tesseract)</div>
            <div class="card-desc">Text extraction from scanned content &amp; images</div>
          </div>

          <div class="tool-card">
            <span class="card-icon">🔗</span>
            <div class="card-title">RAG</div>
            <div class="card-desc">Retrieval-Augmented Generation for AI responses</div>
          </div>

          <div class="tool-card highlighted">
            <span class="card-icon">⚙️</span>
            <div class="card-title">n8n Workflow</div>
            <div class="card-desc">Automation workflow orchestration platform</div>
          </div>

          <div class="tool-card">
            <span class="card-icon">🎯</span>
            <div class="card-title">Reinforcement Learning</div>
            <div class="card-desc">AI training through reward-based learning</div>
          </div>

          <div class="tool-card highlighted">
            <span class="card-icon">🌸</span>
            <div class="card-title">Bloom's Taxonomy</div>
            <div class="card-desc">Educational learning objective classification</div>
          </div>

          <div class="tool-card">
            <span class="card-icon">🕸️</span>
            <div class="card-title">GraphRAG</div>
            <div class="card-desc">Graph-based Retrieval-Augmented Generation</div>
          </div>

          <div class="tool-card highlighted">
            <span class="card-icon">🤖</span>
            <div class="card-title">Agentic Pipeline</div>
            <div class="card-desc">Autonomous AI agent workflow systems</div>
          </div>

          <div class="tool-card">
            <span class="card-icon">🧠</span>
            <div class="card-title">OpenAI API</div>
            <div class="card-desc">Large Language Models and embeddings</div>
          </div>

